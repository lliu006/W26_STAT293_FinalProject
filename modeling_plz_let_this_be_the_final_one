# ANALYSIS DRAFT

```{r}
heart_data$hs <- relevel(factor(heart_data$hs),
                         ref = "Stentless valve")

heart_data <- heart_data %>%
  mutate(num = factor(num),
         sex = factor(sex,
                      levels = c(0,1),
                      labels = c("Male", "Female")),
         prenyha = factor(prenyha),
         redo = factor(redo),
         dm = factor(dm),
         acei = factor(acei),
         con.cabg = factor(con.cabg),
         lv = factor(lv),
         emergenc = factor(emergenc),
         hc = factor(hc),
         sten.reg.mix = factor(sten.reg.mix)
         )
```

```{r}
lmm0 <- lme(
  fixed = log.lvmi ~ time * hs + sex + age + bsa + lvh + prenyha + redo + dm + lv,
  random = ~ time | num,
  data = heart_data
  )
summary(lmm0)
```

WHAT I GOT FOR LMM:
- interaction: 0.005 No evidence that rate of LVMI change differs by valve type
- time: -0.012 LVMI slighlty decreases over time after surgery 
- hs: 0.068 Patients with stentless valves have slightly higher LVMI, but not statistically convincing.
- sex: -0.218 Females have lower LVMI on average
- age: 0.001 not significant
- bsa: -0.274 Larger BSA is associated with lower indexed LVMI
- lvh: -0.114 patients with preoperative LVH have slightly lower postoperative LVMI
- prenyha: -0.005 not significant
- redo: -0.007 Patients with prior surgery have slightly higher LVMI, but effect is small
- dm: -0.191 slightly lower LVMI among diabetes 
- lv: 0.038 higher lvef means higher lmvi

```{r}
survival_fit <- coxph(
  Surv(fuyrs, status) ~ hs +
    sex + age + bsa + lvh + prenyha +
    redo + dm + lv,
  data = heart_data
)
summary(survival_fit)
```

WHAT I GOT FOR SURVIVAL ANALYSIS:
- hr: 2.02 patients with stentless valves have about 2× hazard of death
- age: 1.18 each additional year of age means 18% higher hazard 
- lvh: 0.14 
- redo 0.494 prior surgery associated with lower observed hazard
- lv: 2.49 worse LV function means higher mortality risk

# lmm full 

```{r}
jm_data <- heart_data[!duplicated(heart_data$num), ]

lme_full <- lme(
  fixed = log.lvmi ~ time + hs + sex + age + bsa + lvh + prenyha + redo + dm + lv,
  random = ~ time | num,
  data = heart_data)
```

# lmm model assumptions check

## residuals vs fitted (linearity + homoscedasticity)

```{r}
lmm_df <- data.frame(fitted = fitted(lme_full),
                     resid = resid(lme_full,
                                   type = "pearson"))

ggplot(lmm_df,
       aes(x = fitted,
           y = resid)) +
  geom_point(alpha = 0.3) +
  geom_hline(yintercept = 0,
             linetype = "dashed") +
  labs(title = "LMM: Pearson Residuals vs. Fitted",
       x = "Fitted values",
       y = "Pearson residuals")
```

## normal Q-Q plot of residuals (approx normality)

```{r}
ggplot(lmm_df,
       aes(sample = resid)) +
  stat_qq(alpha = 0.3) +
  stat_qq_line() +
  labs(title = "LMM: Q-Q Plot of Pearson Residuals")
```

## random effects normality + correlation

```{r}
re <- ranef(lme_full)

re_df <- data.frame(b0 = re[, "(Intercept)"],
                    b1 = re[, "time"])

ggplot(re_df,
       aes(sample = b0)) +
  stat_qq(alpha = 0.6) + 
  stat_qq_line() +
  labs(title = "LMM: Q-Q Plot of Random Intercepts")

ggplot(re_df,
       aes(sample = b1)) +
  stat_qq(alpha = 0.6) + 
  stat_qq_line() +
  labs(title = "LMM: Q-Q Plot of Random Slopes (time)")

ggplot(re_df, 
       aes(x = b0,
           y = b1)) +
  geom_point(alpha = 0.6) +
  labs(title = "LMM: Random Effects (Intercept vs Slope)",
       x = "Random intercept", y = "Random slope (time)")
```

## check if nonlinear time is needed 

```{r}
lme_quad <- update(lme_full,
                   fixed = . ~ . + I(time^2),
                   method = "REML")

anova(lme_full, lme_quad)
```

There is no strong evidence that adding a quadratic term improves model fit.

